// Example: n-queens. Returns all solutions. This variant uses bitmasks.
// SPDX-License-Identifier: CC0-1.0

nqueens(n) -> nqueens_aux(0,(2<<n)-2,{});

// nqueens_aux(column_choices_sofar, column_choices_todo, rows_done)
nqueens_aux(0,0,solution) -> {solution};
nqueens_aux(_,0,solution) -> {};
nqueens_aux(col_so_far,col_todo,rows_done) -> nqueens_aux2(col_so_far,col_todo-(1<<(count_trailing_zeros col_todo)),count_trailing_zeros col_todo, rows_done);

nqueens_aux2(col_so_far,col_todo,c,rows_done) ->
    {..nqueens_try(col_so_far,col_todo,c,rows_done),
     ..nqueens_aux(col_so_far+(1<<c),col_todo,rows_done)};

nqueens_try(col_so_far,col_todo,c,rows_done)::attack(c,1,rows_done) -> {}; // no solutions here
nqueens_try(col_so_far,col_todo,c,rows_done) -> nqueens_aux(0,col_so_far+col_todo,{c,..rows_done}); // got another row

attack(c,offset,{}) -> false;
attack(c,offset,{x,..rest}) :: c+offset==x || c-offset==x -> true;
attack(c,offset,{_,..rest}) -> attack(c,offset+1,rest);
